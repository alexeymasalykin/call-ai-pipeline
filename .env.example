# Novofon (Data API 2.0)
NOVOFON_LOGIN=
NOVOFON_PASSWORD=

# Yandex Cloud
YANDEX_CLOUD_FOLDER_ID=
YANDEX_CLOUD_SA_KEY_FILE=service_account_key.json
YANDEX_S3_BUCKET=call-ai-pipeline-audio
YANDEX_S3_ACCESS_KEY=
YANDEX_S3_SECRET_KEY=
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net

# ProxyAPI (LLM)
PROXYAPI_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.proxyapi.ru/openai/v1

# Bitrix24
BITRIX24_WEBHOOK_URL=
BITRIX24_QA_ENTITY_TYPE_ID=1040
BITRIX24_QA_FIELD_MAP={"product_detected":"ufCrmXX_field1","segment_detected":"ufCrmXX_field2","manager_name":"ufCrmXX_field3","total_score":"ufCrmXX_field4","exit_to_dm_score":"ufCrmXX_field5","opening_score":"ufCrmXX_field6","development_score":"ufCrmXX_field7","closing_score":"ufCrmXX_field8","objection_score":"ufCrmXX_field9","critical_errors":"ufCrmXX_field10","strengths":"ufCrmXX_field11","improvements":"ufCrmXX_field12","summary":"ufCrmXX_field13"}
BITRIX24_COMPANY_SEGMENT_FIELD=UF_CRM_XXXXXXXXXX

# Redis
REDIS_URL=redis://redis:6379/0

# App
MIN_CALL_DURATION=15
WEBHOOK_SECRET=change-me
ALERT_WEBHOOK_URL=
ADMIN_TOKEN=change-me
LOG_LEVEL=INFO
CRM_RETRY_DELAY_SECONDS=1800
CRM_RETRY_MAX_ATTEMPTS=3
CORS_ORIGINS=https://your-dashboard.example.com
